# Supabase Configuration
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini API Configuration
VITE_GEMINI_API_KEY=your-gemini-api-key

# BuildwellAI Compliance Orchestration API
# Leave blank to use demo mode (built-in UK Building Regulations logic)
# When the compliance orchestration agent is deployed, set this to its endpoint
VITE_COMPLIANCE_API_URL=

# OpenWeather API (optional — weather risk assessment on site inspections)
VITE_OPENWEATHER_API_KEY=your-openweather-api-key